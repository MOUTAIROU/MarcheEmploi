{
    // Visit https://aka.ms/tsconfig to read more about this file
    "compilerOptions": {
        "module": "esnext",
        "moduleResolution": "bundler",
        "target": "es2020",
        "verbatimModuleSyntax": false,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "strict": true,
        "resolveJsonModule": true,
        "outDir": "dist"
    },
    "include": ["src", "tsconfig.json"]
}
